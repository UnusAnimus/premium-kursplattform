# Arkanum Akademie – Umgebungsvariablen
# Kopiere diese Datei als .env.local und fülle die Werte aus.

# NextAuth Konfiguration
# Generiere ein sicheres Secret mit: openssl rand -hex 32
NEXTAUTH_SECRET=HIER_EIN_SICHERES_SECRET_EINTRAGEN
NEXTAUTH_URL=http://localhost:3000

# Super Admin Konfiguration
# Trage hier deine E-Mail-Adresse ein, um den Super Admin einzurichten.
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_NAME=Admin

# Passwort für den Super Admin (nur für die Entwicklung)
# Im Produktionsbetrieb verwende stattdessen SUPER_ADMIN_PASSWORD_HASH (bcrypt-Hash)
# WICHTIG: Setze im Produktionsbetrieb NIEMALS SUPER_ADMIN_PLAIN_PASSWORD – nutze nur den Hash!
SUPER_ADMIN_PLAIN_PASSWORD=HIER_EIN_SICHERES_PASSWORT_EINTRAGEN

# Für Produktion: bcrypt-Hash des Passworts (SUPER_ADMIN_PLAIN_PASSWORD wird dann ignoriert)
# Generiere den Hash mit: node -e "require('bcryptjs').hash('DeinPasswort', 12).then(console.log)"
# SUPER_ADMIN_PASSWORD_HASH=

# Datenbank (PostgreSQL via Prisma ORM)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arkanum?schema=public

# E-Mail (für Kontaktformular und Passwort-Reset)
# Ohne SMTP-Konfiguration wird im Entwicklungsmodus ein Ethereal-Testkonto genutzt.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@arkanum-akademie.de
# SMTP_PASS=
# Empfänger-E-Mail für Kontaktformular (Standard: SMTP_USER)
# CONTACT_EMAIL=kontakt@arkanum-akademie.de

# Stripe (für Zahlungen)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Google OAuth (für "Mit Google anmelden")
# 1. Projekt in Google Cloud Console erstellen: https://console.cloud.google.com
# 2. APIs & Dienste → OAuth 2.0-Anmeldedaten → Webanwendung erstellen
# 3. Autorisierte Weiterleitungs-URIs hinzufügen:
#    - http://localhost:3000/api/auth/callback/google  (Entwicklung)
#    - https://deine-domain.de/api/auth/callback/google  (Produktion)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
