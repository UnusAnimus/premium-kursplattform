# Arkanum Akademie – Test-Umgebungsvariablen
# Kopiere diese Datei als .env.test.local für lokale E2E-Tests.
# NICHT in Git commiten.

# NextAuth – Pflicht
NEXTAUTH_SECRET=test-secret-minimum-32-chars-here
NEXTAUTH_URL=http://localhost:3000

# Super Admin (wird für Admin-E2E-Tests verwendet)
# Muss mit einer laufenden Next.js-Instanz übereinstimmen.
SUPER_ADMIN_EMAIL=admin@test.local
SUPER_ADMIN_NAME=Test Admin
SUPER_ADMIN_PLAIN_PASSWORD=TestAdmin123!

# Datenbank (Test-DB – darf nicht die Produktions-DB sein!)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arkanum_test

# E2E-Test-Zugangsdaten
# Diese Werte werden von den Playwright-Tests gelesen.
E2E_ADMIN_EMAIL=admin@test.local
E2E_ADMIN_PASSWORD=TestAdmin123!
E2E_MEMBER_EMAIL=mitglied@arkanum-akademie.de
E2E_MEMBER_PASSWORD=Member123!
